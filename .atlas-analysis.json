  },
  "keyFeatures": [
    "Product catalog with categories, media gallery, pricing, and stock management",
    "Order management with payment integration (Bold payment gateway) and order state tracking",
    "User authentication via JWT with custom registration fields (firstName, lastName)",
    "Wishlist functionality for saving favorite products per user",
    "Address book for managing multiple shipping addresses per user",
    "Email notifications via SMTP/Nodemailer integration",
    "PostgreSQL database with support for MySQL and SQLite",
    "Draft and publish workflow for products and categories"
  ],
  "publicApiSurface": [
    "GET /api/products",
    "GET /api/products/:id",
    "POST /api/products",
    "PUT /api/products/:id",
    "DELETE /api/products/:id",
    "GET /api/categories",
    "GET /api/categories/:id",
    "GET /api/orders",
    "GET /api/orders/:id",
    "POST /api/payment-order",
    "GET /api/addresses",
    "POST /api/addresses",
    "PUT /api/addresses/:id",
    "DELETE /api/addresses/:id",
    "GET /api/wishlists",
    "POST /api/wishlists",
    "DELETE /api/wishlists/:id",
    "POST /api/auth/local/register",
    "POST /api/auth/local"
  ]
}
