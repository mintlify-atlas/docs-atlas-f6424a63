            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": ["api-reference/overview"]
          },
          {
            "group": "Products",
            "pages": ["api-reference/products/list", "api-reference/products/get", "api-reference/products/create", "api-reference/products/update", "api-reference/products/delete"]
          },
          {
            "group": "Categories",
            "pages": ["api-reference/categories/list", "api-reference/categories/get"]
