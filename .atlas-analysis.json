{
  "projectType": "api-service",
  "projectName": "Cafe Acacias E-commerce API",
  "projectDescription": "A Strapi-powered headless CMS backend for the Cafe Acacias e-commerce platform, providing REST APIs for products, categories, orders, addresses, wishlists, and user authentication.",
  "theme": "almond",
  "primaryColor": "#5049fc",
  "lightColor": "#a49cfc",
  "darkColor": "#242365",
  "navigation": {
