            "group": "Get Started",
            "pages": ["introduction", "quickstart", "authentication"]
          },
          {
            "group": "Configuration",
            "pages": ["configuration/environment", "configuration/database", "configuration/email"]
          },
          {
            "group": "Data Models",
            "pages": [
              "data-models/product",
              "data-models/category",
              "data-models/order",
              "data-models/address",
